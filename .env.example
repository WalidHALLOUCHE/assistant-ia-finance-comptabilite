# ============================================================================
# AI Provider Configuration
# ============================================================================
# Options:
# - ollama: local mode, no API key required
# - gemini: Google Gemini API for chat and embeddings
# - groq: Groq API for chat; use EMBEDDING_PROVIDER=gemini for full API RAG
AI_PROVIDER=ollama

# ============================================================================
# Ollama Local Configuration
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=20

# ============================================================================
# Google Gemini API Configuration
# ============================================================================
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001

# ============================================================================
# Groq API Configuration
# ============================================================================
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Embedding Provider
# ============================================================================
# Options: ollama or gemini
# For AI_PROVIDER=gemini, this defaults to gemini.
# For AI_PROVIDER=groq, set EMBEDDING_PROVIDER=gemini if you want RAG without Ollama.
EMBEDDING_PROVIDER=

# ============================================================================
# Vector Store Configuration
# ============================================================================
VECTOR_STORE_PATH=vector_store
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================================
# Application Settings
# ============================================================================
LOG_LEVEL=INFO
MAX_TOKENS=1500
TEMPERATURE=0.7
